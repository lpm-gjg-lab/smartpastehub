{
  "name": "smartpastehub",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.main.json\" \"vite dev\"",
    "dev:desktop": "concurrently -k \"tsc -w -p tsconfig.main.json\" \"vite dev --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on tcp:5173 file:dist/main/main/index.js file:dist/main/main/preload.js && cross-env NODE_ENV=development electron .\"",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:electron:wait": "wait-on tcp:5173 file:dist/main/main/index.js file:dist/main/main/preload.js && cross-env NODE_ENV=development electron .",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:renderer": "vite dev",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build:extension": "webpack --config extension/webpack.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "package": "electron-builder",
    "start": "electron .",
    "start:prod": "npm run build && electron .",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.0.0-rc.12",
    "electron": "^33.0.0",
    "electron-store": "^9.0.0",
    "highlight.js": "^11.10.0",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "toml": "^3.0.0",
    "turndown": "^7.1.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@playwright/test": "^1.52.0",
    "@vitest/utils": "^3.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron-builder": "^25.1.8",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4",
    "wait-on": "^8.0.1"
  }
}
