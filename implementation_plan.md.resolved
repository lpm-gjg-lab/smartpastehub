│   │   ├── History.tsx        # History browser UI
│   │   ├── Snippets.tsx       # Snippet manager UI
│   │   └── Templates.tsx      # Template manager UI (BARU)
│   └── components/
│       ├── HistoryList.tsx
│       ├── SnippetCard.tsx
│       ├── TemplateEditor.tsx # Template editor (BARU)
│       └── UsageMeter.tsx     # Free tier usage display
```

